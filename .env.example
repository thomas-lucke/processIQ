# =============================================================================
# ProcessIQ — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================


# =============================================================================
# API Keys
# At least one LLM provider key is required. LangSmith is optional.
# =============================================================================

OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
# LANGSMITH_API_KEY=your-langsmith-key-here


# =============================================================================
# LangSmith Observability (optional)
# =============================================================================

LANGSMITH_TRACING=false
# Use the EU endpoint (config.py default) or the US endpoint:
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=processiq


# =============================================================================
# Global LLM Settings
# These are the defaults for all tasks. Per-task overrides are below.
# =============================================================================

# Provider: anthropic | openai | ollama
LLM_PROVIDER=openai

# Model: leave empty to use the provider default defined in model_presets.py
LLM_MODEL=

LLM_TEMPERATURE=0.0

# Set to false to disable LLM-generated explanations (faster, cheaper for testing)
LLM_EXPLANATIONS_ENABLED=true


# =============================================================================
# Ollama (local LLM — developer use only)
#
# Ollama runs models locally. It requires no API key but the model must be
# pulled first: `ollama pull llama3.2:3b`
#
# Which model to use:
#   - llama3.2:3b  — recommended for CPU. Fast enough for structured output.
#   - qwen3:8b     — better quality but slow on CPU (may time out).
#
# The analysis task uses with_structured_output() which requires the model to
# return valid JSON conforming to a schema. Not all models handle this well.
# Thinking/reasoning models (qwen3, deepseek-r1) must have reasoning disabled
# — this is done automatically in llm.py.
#
# Performance warning: on CPU-only hardware, complex tasks (analysis) can take
# 2–5+ minutes per request. OLLAMA_TIMEOUT controls when the app gives up.
# Increase it if you have a slow machine and are willing to wait.
#
# Note: extraction always falls back to OpenAI when Ollama is selected.
# An OpenAI API key is still required even in Ollama mode.
# =============================================================================

# Set to false in cloud deployments where Ollama is not available.
# When false, selecting Ollama in the UI returns a clear error instead of timing out.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# Timeout in seconds for Ollama requests. Default: 120 (2 minutes).
# Increase to 300+ on CPU-only machines if analysis requests are timing out.
OLLAMA_TIMEOUT=120


# =============================================================================
# Per-Task LLM Overrides
#
# Each task can use a different model/provider. Unset fields inherit from the
# global settings above. Format: JSON object with optional keys:
#   provider    — anthropic | openai | ollama
#   model       — model name string
#   temperature — float 0.0–2.0
#
# Tasks:
#   extraction      — parse user input into structured process data
#   clarification   — ask follow-up questions when input is too vague
#   explanation     — generate improvement suggestions after extraction
#   analysis        — main LLM analysis (issues, recommendations)
#   investigation   — agentic tool-calling loop (OpenAI/Anthropic only)
#
# Ollama example — use a smaller model for fast tasks, larger for analysis:
#   LLM_TASK_EXTRACTION='{"model": "llama3.2:3b"}'
#   LLM_TASK_ANALYSIS='{"model": "qwen3:8b"}'
#
# Mixed-provider example — Ollama for cheap tasks, Anthropic for analysis:
#   LLM_TASK_EXTRACTION='{"provider": "ollama", "model": "llama3.2:3b"}'
#   LLM_TASK_ANALYSIS='{"provider": "anthropic", "model": "claude-haiku-4-5-20251001"}'
# =============================================================================

# LLM_TASK_EXTRACTION=
# LLM_TASK_CLARIFICATION=
# LLM_TASK_EXPLANATION=
# LLM_TASK_ANALYSIS=
# LLM_TASK_INVESTIGATION=


# =============================================================================
# Application Settings
# =============================================================================

# CORS — set to your Vercel frontend URL in production (e.g. https://processiq.vercel.app)
# Defaults to http://localhost:3000 if not set.
ALLOWED_ORIGIN=http://localhost:3000

LOG_LEVEL=INFO  # DEBUG for development, INFO for normal use
CONFIDENCE_THRESHOLD=0.6  # Minimum confidence to proceed without asking for more data

# Agentic investigation loop
AGENT_MAX_CYCLES=3  # Max investigation turns per analysis (1–10)

# Demo mode — set to true in Railway to grey out Ollama, deep analysis, and investigation depth
DEMO_MODE=false


# =============================================================================
# Persistence
# =============================================================================

PERSISTENCE_ENABLED=true
# PERSISTENCE_DB_PATH=data/processiq.db  # SQLite path for profiles, sessions, and checkpoints


# =============================================================================
# Storage
# =============================================================================

# CHROMA_PERSIST_DIRECTORY=.chroma  # ChromaDB vector store directory
# DOCUMENT_INGESTION_ENABLED=true   # Set to false to disable PDF/DOCX/image ingestion via Docling
